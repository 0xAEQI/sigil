**/target/
*.swp
*.swo
.DS_Store

# Runtime state
.sigil/sessions/
.sigil/checkpoints/
projects/*/.sigil/
agents/*/.sigil/
**/.tasks/
**/.quests/
*.db
*.db-wal
*.db-shm

# Local config (commit sigil.example.toml instead)
config/sigil.toml
config/platform.toml
apps/ui/node_modules/
apps/ui/dist/
apps/ui/*.tsbuildinfo
apps/ui/.env
apps/ui/.env*.local

# Agent runtime state (ignore), but track agent templates (ship with Sigil)
